# 文字檔統一以 LF 入庫，避免 Windows CRLF 讓 hook 蓋章時改壞行尾。
* text=auto eol=lf

*.cpp  text eol=lf
*.cc   text eol=lf
*.cxx  text eol=lf
*.hpp  text eol=lf
*.h    text eol=lf
*.md   text eol=lf
*.sh   text eol=lf
*.tmpl text eol=lf

# Windows 專用腳本維持 CRLF
*.ps1  text eol=crlf

# 不做行尾正規化的二進位
*.png  binary
*.jpg  binary
